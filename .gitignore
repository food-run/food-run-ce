# tell Git which files/folders to ignore when tracking changes

# installed from package.json
node_modules/

# build output from client and server are regeneratable
dist/
build/
server-build/

# Angular CLI cache
.angular/

# mac-specific metadata files
.DS_Store

# files that may contain secrets
.env
.env.production
.env.development

# python cache artifacts can leak local execution details
__pycache__/
*.py[cod]
*.pyo

# not used right now
supabase.config.ts

# opencode live coordination
docs/coordination/**
!docs/templates/coordination/**
