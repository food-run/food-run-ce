{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "default_agent": "pm",
  "watcher": {
    "ignore": [
      ".git/**",
      "node_modules/**",
      "dist/**",
      "build/**",
      ".venv/**",
      "coverage/**",
      "docs/coordination/**"
    ]
  },
  "permission": {
    "edit": "ask",
    "webfetch": "ask",
    "skill": {
      "*": "allow"
    },
    "bash": {
      "*": "ask",
      "pwd": "allow",
      "ls *": "allow",
      "find *": "allow",
      "sort *": "allow",
      "tree *": "allow",
      "rg *": "allow",
      "grep *": "allow",
      "sed -n *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "cat *": "allow",
      "date *": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "printf *": "allow",
      "true": "allow",
      "git status *": "allow",
      "git branch *": "allow",
      "git show *": "allow",
      "git ls-files *": "allow",
      "git log *": "allow",
      "git rev-parse*": "allow",
      "git branch*": "allow",
      "git add *": "ask",
      "git commit *": "ask",
      "git switch *": "ask",
      "git checkout *": "ask",
      "git mv *": "ask",
      "git restore *": "ask",
      "git merge *": "deny",
      "git rebase *": "deny",
      "git push *": "deny",
      "rm *": "deny"
    }
  }
}
